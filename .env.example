# Copy to .env and fill in your values
# .env is gitignored — safe for secrets

# Auth: use SKIP_AUTH=1 for local dev (no Supabase needed).
# Google OAuth only works on the deployed app because Supabase
# redirects to the Site URL after sign-in, which is the Render URL.
SKIP_AUTH=1
DASH_DEBUG=1

# Only needed when SKIP_AUTH=0 (production / auth testing):
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_KEY=your-anon-public-key
